cases/**/*.vtk
cases/**/*.vtp
cases/**/*.dat
cases/**/*.out
cases/**/*.bin
cases/**/*.csv
cases/**/*.xml
cases/**/*.stl

# Keep processed results under data/results versionable if desired
!data/results/*.csv
!data/results/*_gci.json
!data/results.sqlite

# Codex local context
.codex_context/
CODEX_START_HERE.md
codex_context_sph.zip

