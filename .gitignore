# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo

# DualSPHysics binaries (heavy)
*.bi4
*.cbi4
*.obi4
*.ibi4
*.vtk
*.ply
*.obj
*.out

# STL in cases/ (copies, not originals)
cases/**/*.stl

# Simulation raw outputs — excluir binarios pesados, mantener CSVs clave
cases/*/lhs_*_out/*.bi4
cases/*/lhs_*_out/*.cbi4
cases/*/lhs_*_out/*.obi4
cases/*/lhs_*_out/*.ibi4
cases/*/lhs_*_out/*.vtk
cases/*/lhs_*_out/*.ply
cases/*/lhs_*_out/PartVTK*/
cases/*/lhs_*_out/PartVTKOut*/

# Processed simulation data — mantener en Git para acceso desde laptop
data/*.log
data/*.pkl

# OS
Thumbs.db
.DS_Store

# Agent internal state
.agente/

# APOS-X source scaffold is kept as historical/tooling material.
# The thesis runtime uses only .apos/ plus the three repo skills under .agents/skills/.
# Existing tracked files remain tracked; this prevents accidental expansion of a second APOS system.
apos-system/**

# DualSPHysics heavy outputs
cases/**/Part*
cases/**/*_out/
cases/**/boulder_properties.txt
cases/**/canal_verificacion.png
