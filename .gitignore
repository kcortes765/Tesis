# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo

# DualSPHysics binaries (heavy)
*.bi4
*.cbi4
*.obi4
*.ibi4
*.vtk
*.ply
*.obj
*.out

# STL in cases/ (copies, not originals)
cases/**/*.stl

# Simulation raw outputs — excluir binarios pesados, mantener CSVs clave
cases/*/lhs_*_out/*.bi4
cases/*/lhs_*_out/*.cbi4
cases/*/lhs_*_out/*.obi4
cases/*/lhs_*_out/*.ibi4
cases/*/lhs_*_out/*.vtk
cases/*/lhs_*_out/*.ply
cases/*/lhs_*_out/PartVTK*/
cases/*/lhs_*_out/PartVTKOut*/

# Processed simulation data — mantener en Git para acceso desde laptop
data/*.log
data/*.pkl

# OS
Thumbs.db
.DS_Store

# Agent internal state
.agente/

# DualSPHysics heavy outputs
cases/**/Part*
cases/**/*_out/
cases/**/*.bi4
cases/**/*.vtk
cases/**/*.vtp
cases/**/*.dat
cases/**/*.out
cases/**/*.bin
cases/**/*.csv
cases/**/*.xml
cases/**/*.stl

# Keep processed results under data/results versionable if desired
!data/results/*.csv
!data/results/*_gci.json
!data/results.sqlite

# Codex local context
.codex_context/

# Runtime production state and heavy processed outputs
data/production_status.json
data/production_*.log
data/processed/

# Lightweight audited exports are intended to be versionable
!exports/
!exports/**
